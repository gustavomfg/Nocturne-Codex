{
  "name": "nocturne-codex",
  "private": true,
  "version": "0.6.0-beta",
  "description": "Cliente desktop local e independente para desenvolvimento assistido pelo Codex CLI.",
  "license": "MIT",
  "author": "Nocturne Codex contributors",
  "type": "module",
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22.12 <23",
    "npm": ">=10.9 <11"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:app": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 && npm run lint:design",
    "lint:design": "node scripts/check-design-system.mjs",
    "test": "node scripts/run-tests.mjs",
    "test:renderer": "playwright test",
    "test:renderer:update": "playwright test --update-snapshots",
    "test:watch": "node scripts/run-tests.mjs --watch",
    "package": "npm run build && electron-builder",
    "package:dir": "npm run build && electron-builder --dir",
    "smoke:package": "node scripts/smoke-package.mjs",
    "checksums": "node scripts/smoke-package.mjs --checksums",
    "verify:release-metadata": "node scripts/verify-release-metadata.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^8.1.4",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^4.1.10"
  },
  "main": "dist-electron/main.js",
  "allowScripts": {
    "electron@43.1.0": true,
    "better-sqlite3@12.11.1": true,
    "esbuild@0.27.4": true,
    "electron-winstaller@5.4.0": true
  }
}
